# RV-Insights environment template

# App
# APP_NAME is the human-readable application name
APP_NAME=RV-Insights
# APP_VERSION is the current version string
APP_VERSION=0.1.0
DEBUG=false

# CORS
# Comma-separated origins allowed to access the API
CORS_ORIGINS=http://localhost:5173

# MongoDB
# URI for MongoDB connection
MONGODB_URI=mongodb://localhost:27017
# Database name to use
MONGODB_DB=rv_insights

# PostgreSQL
# DSN/URI for PostgreSQL
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/rv_insights

# Redis
# Redis connection URL
REDIS_URI=redis://localhost:6379/0

# Security / JWT
# Secret key used to sign JWT tokens
JWT_SECRET=change-me
# Algorithm used to sign JWT tokens
JWT_ALGORITHM=HS256
# Access token expiry in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Pipeline
# Maximum number of review iterations in a pipeline step
MAX_REVIEW_ITERATIONS=3
# Maximum allowed cost per case in the pipeline
MAX_COST_PER_CASE=10.0

# Other
# RV_INSIGHTS_TESTING=1 will skip real DB connections to ease unit testing
# RV_INSIGHTS_TESTING=1

# ─── Sprint 3+ ───────────────────────────────────────────

# LLM — Anthropic (Claude Agent SDK, used for explore/develop/test nodes)
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# LLM — OpenAI (OpenAI Agents SDK, used for plan/review nodes + chat)
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Chat — default model for new sessions
CHAT_DEFAULT_MODEL_CONFIG_ID=

# ToolUniverse — RISC-V tool catalog service
TOOLUNIVERSE_BASE_URL=http://localhost:8100
TOOLUNIVERSE_API_KEY=

# IM — Lark (Feishu)
LARK_APP_ID=
LARK_APP_SECRET=
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=

# IM — WeChat bridge
WECHAT_BRIDGE_ENABLED=false
WECHAT_BRIDGE_URL=http://localhost:8200

# IM — general
IM_ENABLED=false
IM_RESPONSE_TIMEOUT=300
IM_MAX_MESSAGE_LENGTH=5000

# Celery — task-service (scheduled tasks)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
TASK_SERVICE_URL=http://localhost:8300

# File storage
FILE_STORAGE_PATH=/tmp/rv-insights/files
FILE_ALLOWED_PREFIXES=/tmp,/app

# Statistics
STATISTICS_COST_CURRENCY=USD

# Notifications
NOTIFICATION_QUEUE_MAX_SIZE=256
