# RV-Insights environment template

# App
# APP_NAME is the human-readable application name
APP_NAME=RV-Insights
# APP_VERSION is the current version string
APP_VERSION=0.1.0
DEBUG=false

# CORS
# Comma-separated origins allowed to access the API
CORS_ORIGINS=http://localhost:5173

# MongoDB
# URI for MongoDB connection
MONGODB_URI=mongodb://localhost:27017
# Database name to use
MONGODB_DB=rv_insights

# PostgreSQL
# DSN/URI for PostgreSQL
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/rv_insights

# Redis
# Redis connection URL
REDIS_URI=redis://localhost:6379/0

# Security / JWT
# Secret key used to sign JWT tokens
JWT_SECRET=change-me
# Algorithm used to sign JWT tokens
JWT_ALGORITHM=HS256
# Access token expiry in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Pipeline
# Maximum number of review iterations in a pipeline step
MAX_REVIEW_ITERATIONS=3
# Maximum allowed cost per case in the pipeline
MAX_COST_PER_CASE=10.0

# Other
# RV_INSIGHTS_TESTING=1 will skip real DB connections to ease unit testing
# RV_INSIGHTS_TESTING=1
