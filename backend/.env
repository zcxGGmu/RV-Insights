DEFAULT_LLM_API_KEY=sk-c83004a45ce5c4ce4f81fe0b8fa93b61
DEFAULT_LLM_TEMPERATURE=0.7
DEFAULT_LLM_CONTEXT_WINDOW=128000

# Explorer — 走 DEFAULT_LLM fallback（ANTHROPIC_API_KEY 留空）
